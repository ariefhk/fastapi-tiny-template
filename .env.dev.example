# APP
ENVIRONMENT=dev
APP_NAME="Tiny Api"
APP_VERSION=1.0.0
DEBUG=true

# DEPLOY
HOST=0.0.0.0
PORT=8000
WORKERS=1
KEEP_ALIVE=5
LIMIT_CONCURRENCY=1000

# JWT
JWT_SECRET_KEY=dev-secret-key-change-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# DATABASES
DB_AUTO_MIGRATE=true
DB_ENABLED=true
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=
DB_USER=postgres
DB_PASSWORD=password

# CORS
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE
CORS_ALLOW_HEADERS=*

# CACHE
CACHE_ENABLED=true
CACHE_URL=redis://localhost:6379/0
CACHE_DEFAULT_TTL=3600

# RATE LIMIT
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URI=redis://localhost:6379/1
RATE_LIMIT_DEFAULT=

# LOG
LOG_REQUESTS=true
LOG_REQUEST_BODY=true
LOG_RESPONSE_BODY=true
LOG_MAX_BODY_BYTES=10000
LOG_MAX_LIST_ITEMS=5
LOG_MAX_STRING_LENGTH=200
LOG_SKIP_PATHS=/docs,/redoc,/openapi.json

# SSH TUNNEL — HOP 1 (local → jump host or direct to DB host)
DB_SSH_ENABLED=false
DB_SSH_HOST=
DB_SSH_PORT=22
DB_SSH_USER=
DB_SSH_PRIVATE_KEY_PATH=

# SSH TUNNEL — HOP 2 (jump host → DB host, leave DB_SSH_2_ENABLED=false for single hop)
DB_SSH_2_ENABLED=false
DB_SSH_2_HOST=
DB_SSH_2_PORT=22
DB_SSH_2_USER=
DB_SSH_2_PRIVATE_KEY_PATH=

# SSH TUNNEL — FINAL DESTINATION (used by whichever hop is last)
DB_SSH_REMOTE_BIND_HOST=127.0.0.1
DB_SSH_REMOTE_BIND_PORT=5432

# CELERY
CELERY_ENABLED=false
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3
